# ============================================================================
# Code-Repo: nur Quellcode, NIEMALS Daten oder Secrets
# Daten wohnen unter ~/Disco/ (siehe DISCO_WORKSPACE in .env)
# ============================================================================

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.python-version

# Environment / Secrets
.env
.env.local

# ---------------------------------------------------------------------------
# Schutznetz: falls jemand versehentlich data/ oder db/ im Repo anlegt
# (eigentlich gehoeren die ins ~/Disco-Workspace, NICHT hierher)
# ---------------------------------------------------------------------------
data/
db/
*.db
*.db-journal
*.db-wal
*.db-shm
.msal_token_cache.json

# Kunden-Daten-Exporte (SharePoint-Feeds, koennen PII enthalten)
Sharepoint Download/
*.items.txt

# IDE / OS
.vscode/
.idea/
.DS_Store

# Claude Code — alles lokale, nicht im Repo
.claude/

# Logs
*.log
