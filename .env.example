# ---------------------------------------------------------------------------
# Agent (Phase 2a) — Microsoft Foundry Agent Service
# Region: Sweden Central (DSGVO / EU), Modell: gpt-5.1
# Authentifizierung: DefaultAzureCredential → vorher `az login` im Terminal
# ---------------------------------------------------------------------------
# Foundry-Projekt-Endpoint aus dem Foundry-Portal (→ Project → Overview → Endpoint)
# Format: https://<project>.services.ai.azure.com/api/projects/<project-name>
FOUNDRY_ENDPOINT=https://<dein-foundry-projekt>.services.ai.azure.com/api/projects/<projekt-name>

# Modell-Deployment-Name im Foundry-Projekt
FOUNDRY_MODEL_DEPLOYMENT=gpt-5.1

# Wird nach dem ersten Agent-Create automatisch befüllt (per CLI oder Setup-Script)
FOUNDRY_AGENT_ID=

# Anthropic Claude API (optional — alternativer Provider, bisheriger Chat-Agent)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (optional — Fallback für Direct-OpenAI falls irgendwann nötig)
OPENAI_API_KEY=

# Microsoft Entra ID (für SharePoint-Connector via Device Flow)
# Einrichtung: Entra ID → App-Registrierungen → Neue Registrierung
#   Typ:               "Öffentlicher Client / Nativ" (kein Client Secret nötig)
#   API-Berechtigung:  Microsoft Graph → Files.Read.All (Delegiert)
#   Umleitungs-URI:    https://login.microsoftonline.com/common/oauth2/nativeclient
MSAL_TENANT_ID=<tenant-id-guid>
MSAL_CLIENT_ID=<client-id-guid>

# Azure Document Intelligence (Phase 2)
AZURE_DOC_INTEL_ENDPOINT=https://<dein-resource>.cognitiveservices.azure.com/
AZURE_DOC_INTEL_KEY=

# Azure OpenAI (Phase 2)
AZURE_OPENAI_ENDPOINT=https://<dein-resource>.openai.azure.com/
AZURE_OPENAI_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Disco Workspace — Daten, DB, Projekte AUSSERHALB des Code-Repos
# Default: ~/Disco/ (nicht in iCloud, nicht in Git)
DISCO_WORKSPACE=~/Disco

# Optional: einzelne Pfade ueberschreiben (selten noetig)
DISCO_SYSTEM_DB_PATH=
DISCO_PROJECTS_DIR=
DISCO_LOGS_DIR=

# Aktives Projekt (Slug); i.d.R. nicht hier setzen, sondern ueber Chat-Thread/CLI
DISCO_CURRENT_PROJECT=
